# .streamlit/secrets.toml
#
# This file holds secrets for the hosted Streamlit app.
# DO NOT commit the real secrets.toml to git — only this example.
#
# When deploying to Streamlit Community Cloud, paste these values
# into the "Secrets" section of your app settings (not into the repo).

# The shared password users must enter to access the dashboard.
# Choose something long and random. Share it only with people you
# want to have access to the scanner.
app_password = "change-me-to-a-long-random-password"

# Your Anthropic API key (used for AI recommendations).
# Get one at https://console.anthropic.com/settings/keys
anthropic_api_key = "sk-ant-api03-your-real-key-here"
